@model KerzelPay.ViewModels.TopUpViewModel
@{
    ViewData["Title"] = "Top Up Account";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="mb-3">💰 Top Up Account</h3>
                    <p class="text-muted mb-4">
                        Account: <code>@Model.AccountSerialNumber</code> — @Model.CurrencyCode
                    </p>

                    @if (Model.CurrencyCode == "LBP")
                    {
                        <div class="alert alert-info">
                            <strong>LBP top-ups</strong> are only available through agents.
                            Visit a Kerzel Pay partner store to deposit Lebanese Pounds.
                        </div>
                        <a asp-controller="Account" asp-action="Index" class="btn btn-outline-secondary">
                            ← Back to accounts
                        </a>
                    }
                    else
                    {
                        <form asp-action="Checkout" method="post">
                            <input type="hidden" asp-for="AccountId" />

                            <div class="mb-3">
                                <label asp-for="Amount" class="form-label">Amount</label>
                                <div class="input-group">
                                    <span class="input-group-text">@Model.CurrencySymbol</span>
                                    <input asp-for="Amount" type="number" step="0.01" min="1"
                                           class="form-control" placeholder="50.00" />
                                </div>
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>

                            <div class="alert alert-secondary small">
                                💡 You'll be redirected to Stripe to enter your card details securely.
                                In test mode, use card number <code>4242 4242 4242 4242</code>,
                                any future expiry, and any 3-digit CVC.
                            </div>

                            <div class="d-flex justify-content-between">
                                <a asp-controller="Account" asp-action="Index" class="btn btn-outline-secondary">
                                    Cancel
                                </a>
                                <button type="submit" class="btn btn-success">
                                    Continue to Payment →
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}