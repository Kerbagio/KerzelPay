@model IEnumerable<KerzelPay.Models.Beneficiary>
@{
    ViewData["Title"] = "Beneficiaries";
    var query = ViewBag.Query as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>👥 Beneficiaries</h2>
        <a asp-action="Create" class="btn btn-primary">+ Add Beneficiary</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Index" method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="q" value="@query" class="form-control"
                   placeholder="Search by name, account number, or mobile..." />
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            @if (!string.IsNullOrEmpty(query))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            @if (!string.IsNullOrEmpty(query))
            {
                <h5>No beneficiaries match "@query".</h5>
            }
            else
            {
                <h5>You haven't added any beneficiaries yet.</h5>
                <p class="text-muted">Add your first recipient to start sending money faster.</p>
                <a asp-action="Create" class="btn btn-primary mt-2">Add a beneficiary</a>
            }
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Identifier</th>
                            <th>Added</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model)
                        {
                            <tr>
                                <td><strong>@b.FullName</strong></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(b.AccountSerialNumber))
                                    {
                                        <span class="badge bg-primary">Kerzel Pay</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Mobile (OMT)</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(b.AccountSerialNumber))
                                    {
                                        <code>@b.AccountSerialNumber</code>
                                    }
                                    else
                                    {
                                        @b.MobileNumber
                                    }
                                </td>
                                <td><small class="text-muted">@b.CreatedAt.ToString("dd MMM yyyy")</small></td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@b.Id"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@b.Id"
                                       class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>