@model KerzelPay.ViewComponents.NotificationBellModel

<li class="nav-item dropdown">
    <a class="nav-link position-relative" href="#" role="button"
       data-bs-toggle="dropdown" aria-expanded="false">
        🔔
        @if (Model.UnreadCount > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                @(Model.UnreadCount > 9 ? "9+" : Model.UnreadCount.ToString())
            </span>
        }
    </a>
    <ul class="dropdown-menu dropdown-menu-end" style="min-width: 320px;">
        <li class="dropdown-header d-flex justify-content-between align-items-center">
            <strong>Notifications</strong>
            <a asp-controller="Notification" asp-action="Index" class="small">See all</a>
        </li>
        <li><hr class="dropdown-divider"></li>

        @if (!Model.Recent.Any())
        {
            <li class="dropdown-item-text text-center text-muted py-3">
                No notifications yet
            </li>
        }
        else
        {
            @foreach (var n in Model.Recent)
            {
                <li>
                    <div class="dropdown-item @(!n.IsRead ? "fw-bold" : "")" style="white-space: normal;">
                        <small class="text-muted d-block">
                            @n.CreatedAt.ToString("dd MMM HH:mm")
                            @if (!n.IsRead)
                            {
                                <span class="badge bg-primary ms-1">new</span>
                            }
                        </small>
                        <div>@n.Title</div>
                        <small class="text-muted">@n.Message</small>
                    </div>
                </li>
            }
        }
    </ul>
</li>