@{
    ViewData["Title"] = "Transfer Calculator";
}



<partial name="_TransferCalculator" />

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 text-center">
            <h5 class="mb-3">💡 How it works</h5>
            <div class="row text-start">
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h6>🌍 Live rates</h6>
                            <small class="text-muted">
                                Exchange rates pulled from the European Central Bank — same rates real banks use.
                            </small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h6>💯 No hidden fees</h6>
                            <small class="text-muted">
                                What you see is what you pay. Commission is shown upfront.
                            </small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h6>⚡ Instant transfers</h6>
                            <small class="text-muted">
                                Send money to other Kerzel Pay accounts in seconds, or to mobile numbers for cash pickup.
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>