@using KerzelPay.Constants
@{
    ViewData["Title"] = "Home";
    var currencies = ViewBag.Currencies as IEnumerable<KerzelPay.Models.Currency>;
}

<div class="text-center mt-5">
    <h1 class="display-4">💸 Welcome to Kerzel Pay</h1>
    <p class="lead">Fast, affordable, and reliable money transfers — anywhere, anytime.</p>
    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <div class="mt-4">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg me-2">Get Started</a>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary btn-lg">Login</a>
        </div>
    }
    else
    {
        <p class="mt-3">You're signed in as <strong>@User.Identity.Name</strong>.</p>
    }
</div>

@* === Become an Agent CTA === *@
<div class="container mt-5">
    <div class="card shadow-sm border-0" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
        <div class="card-body p-5 text-center">
            <h3>🏪 Become a Kerzel Pay Agent</h3>
            <p class="lead mb-4">
                Run a local store? Join our partner network and earn commissions on every transaction.
            </p>
            @if (User.Identity?.IsAuthenticated == true && User.IsInRole(Roles.User))
            {
                <a asp-controller="Agent" asp-action="Apply" class="btn btn-light btn-lg">
                    Apply Now →
                </a>
            }
            else if (!(User.Identity?.IsAuthenticated ?? false))
            {
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg">
                    Register & Apply →
                </a>
            }
        </div>
    </div>
</div>

@if (currencies != null && currencies.Any())
{
    <div class="container mt-5">
        <h3 class="text-center mb-4">Supported Currencies</h3>
        <div class="row justify-content-center">
            @foreach (var currency in currencies)
            {
                <div class="col-md-3 mb-3">
                    <div class="card text-center shadow-sm">
                        <div class="card-body">
                            <h2 class="card-title">@currency.Symbol</h2>
                            <h5>@currency.Code</h5>
                            <p class="text-muted mb-0">@currency.Name</p>
                            <small class="text-secondary">1 USD = @currency.ExchangeRateToUsd @currency.Code</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}