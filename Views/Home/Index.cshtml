@using KerzelPay.Constants
@{
    ViewData["Title"] = "Send Money Anywhere — Kerzel Pay";
    var currencies = ViewBag.Currencies as IEnumerable<KerzelPay.Models.Currency>;
}

@* ============================================
   HERO SECTION
   ============================================ *@
<section class="kp-hero">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="kp-eyebrow">💸 Built in Lebanon · For the world</span>
                <h1 class="kp-hero-title">
                    Send money <span class="kp-gradient-text">anywhere</span>.<br />
                    Pay <span class="kp-gradient-text">no surprises</span>.
                </h1>
                <p class="kp-hero-subtitle">
                    Fast, transparent transfers across borders with live exchange rates,
                    flat fees, and instant tracking. Powered by ECB rates.
                </p>

                <div class="kp-hero-ctas">
                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg">
                            Get started free
                        </a>
                        <a asp-controller="Home" asp-action="Calculator" class="btn btn-outline-primary btn-lg">
                            Try the calculator
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Transfer" asp-action="Create" class="btn btn-primary btn-lg">
                            Send money →
                        </a>
                        <a asp-controller="Account" asp-action="Index" class="btn btn-outline-primary btn-lg">
                            My accounts
                        </a>
                    }
                </div>

                <div class="kp-hero-meta">
                    <div class="kp-hero-meta-item">
                        <strong>2 mins</strong>
                        <span>to register</span>
                    </div>
                    <div class="kp-hero-meta-item">
                        <strong>1% fee</strong>
                        <span>flat &amp; visible</span>
                    </div>
                    <div class="kp-hero-meta-item">
                        <strong>4 currencies</strong>
                        <span>and growing</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 d-none d-lg-block">
                <div class="kp-hero-card">
                    <div class="kp-mock-card">
                        <div class="kp-mock-card-top">
                            <span class="kp-mock-chip">●</span>
                            <span class="kp-mock-label">KMP CARD</span>
                        </div>
                        <div class="kp-mock-card-number">KP-2026-A4F2C8</div>
                        <div class="kp-mock-card-bottom">
                            <div>
                                <div class="kp-mock-label">BALANCE</div>
                                <div class="kp-mock-amount">$ 2,540.00</div>
                            </div>
                            <div class="kp-mock-logo">KMP</div>
                        </div>
                    </div>
                    <div class="kp-hero-floating-tx tx-1">
                        <div>↗ Sent to Mom</div>
                        <strong>-€50.00</strong>
                    </div>
                    <div class="kp-hero-floating-tx tx-2">
                        <div>↙ Received</div>
                        <strong class="text-success">+$120.00</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ============================================
   FEATURES SECTION
   ============================================ *@
<section class="kp-section">
    <div class="container">
        <div class="text-center mb-5">
            <span class="kp-eyebrow">Why Kerzel Pay</span>
            <h2 class="kp-section-title">Everything you need. Nothing you don't.</h2>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="kp-feature">
                    <div class="kp-feature-icon" style="background: linear-gradient(135deg, #0066FF, #00D4AA);">⚡</div>
                    <h5>Instant transfers</h5>
                    <p>Account-to-account in seconds. Mobile (OMT) for cash pickup anywhere.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="kp-feature">
                    <div class="kp-feature-icon" style="background: linear-gradient(135deg, #00C896, #00D4AA);">🌍</div>
                    <h5>Live ECB rates</h5>
                    <p>Real exchange rates from the European Central Bank. No hidden markup.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="kp-feature">
                    <div class="kp-feature-icon" style="background: linear-gradient(135deg, #FFB020, #FF8C42);">🛡️</div>
                    <h5>Bank-grade safety</h5>
                    <p>Atomic transactions, role-based access, encrypted passwords.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="kp-feature">
                    <div class="kp-feature-icon" style="background: linear-gradient(135deg, #FF4757, #C44569);">🏪</div>
                    <h5>200+ agents nearby</h5>
                    <p>Cash-in and cash-out at any Kerzel Pay partner store across Lebanon.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@* ============================================
   CURRENCIES STRIP
   ============================================ *@
@if (currencies != null && currencies.Any())
{
    <section class="kp-section kp-section-alt">
        <div class="container">
            <div class="text-center mb-4">
                <span class="kp-eyebrow">Supported currencies</span>
                <h3 class="kp-section-title">Convert across @currencies.Count() global currencies</h3>
            </div>
            <div class="kp-currency-grid">
                @foreach (var c in currencies)
                {
                    <div class="kp-currency-pill">
                        <span class="kp-currency-symbol">@c.Symbol</span>
                        <div>
                            <strong>@c.Code</strong>
                            <small>@c.Name</small>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

@* ============================================
   AGENT CTA
   ============================================ *@
<section class="kp-section">
    <div class="container">
        <div class="kp-cta-card">
            <div class="kp-cta-bg"></div>
            <div class="row align-items-center">
                <div class="col-md-8">
                    <span class="kp-eyebrow text-white" style="opacity: 0.9;">For business owners</span>
                    <h2 class="text-white mb-2">Become a Kerzel Pay agent</h2>
                    <p class="text-white mb-0" style="opacity: 0.85;">
                        Earn commissions on every transaction. Manage cash-in and cash-out from your store.
                    </p>
                </div>
                <div class="col-md-4 text-md-end mt-4 mt-md-0">
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole(Roles.User))
                    {
                        <a asp-controller="Agent" asp-action="Apply" class="btn btn-light btn-lg">
                            Apply now →
                        </a>
                    }
                    else if (!(User.Identity?.IsAuthenticated ?? false))
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg">
                            Register &amp; apply →
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>