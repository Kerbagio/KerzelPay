@model IEnumerable<KerzelPay.Models.Agent>
@{
    ViewData["Title"] = "Find Agents";
}

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin="" />

<div class="container-fluid mt-3">
    <div class="container mb-3">
        <h2>📍 Find a Kerzel Pay Agent</h2>
        <p class="text-muted">
            Click any pin to view store details. @Model.Count() agent@(Model.Count() == 1 ? "" : "s") nearby.
        </p>
    </div>

    @if (!Model.Any())
    {
        <div class="container">
            <div class="alert alert-info text-center">
                No agents available yet. Check back soon!
            </div>
        </div>
    }
    else
    {
        <div id="agentMap" style="height: 600px; width: 100%;"></div>
    }
</div>
@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>

    <script>
        // Initialize map (Beirut default)
        const map = L.map('agentMap').setView([33.8938, 35.5018], 11);

        // ----- TWO TILE LAYERS -----

        // 1) Streets — CartoDB Voyager (clean, modern, free, no key)
        const streets = L.tileLayer(
            'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',
            {
                attribution: '© OpenStreetMap contributors © CARTO',
                subdomains: 'abcd',
                maxZoom: 19
            }
        );

        // 2) Satellite — Esri World Imagery (real satellite photography, free, no key)
        const satellite = L.tileLayer(
            'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
            {
                attribution: 'Tiles © Esri',
                maxZoom: 19
            }
        );

        // Streets is the default
        streets.addTo(map);

        // Layer switcher (top-right toggle widget)
        L.control.layers(
            { '🗺️ Streets': streets, '🛰️ Satellite': satellite },
            null,
            { position: 'topright', collapsed: false }
        ).addTo(map);

        // ----- AGENT MARKERS -----

        // Custom branded pin icon (uses Leaflet's default red icon for clarity)
        const kerzelIcon = L.divIcon({
            html: `
                <div style="
                    background: #0d6efd;
                    width: 36px; height: 36px;
                    border-radius: 50% 50% 50% 0;
                    transform: rotate(-45deg);
                    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
                    display: flex; align-items: center; justify-content: center;
                    border: 3px solid white;">
                    <span style="transform: rotate(45deg); font-size: 16px;">🏪</span>
                </div>
            `,
            className: '',
            iconSize: [36, 36],
            iconAnchor: [18, 36],
            popupAnchor: [0, -36]
        });

        const agents = [
            @foreach (var a in Model)
            {
                    @:{
                    @:    name: "@Html.Raw(Html.Encode(a.StoreName))",
                    @:    address: "@Html.Raw(Html.Encode(a.Address))",
                    @:    hours: "@Html.Raw(Html.Encode(a.WorkingHours ?? "Not specified"))",
                    @:    lat: @a.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    @:    lng: @a.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture)
                    @:},
            }
        ];

        const markers = L.layerGroup();

                agents.forEach(a => {
            const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${a.lat},${a.lng}`;

            const marker = L.marker([a.lat, a.lng], { icon: kerzelIcon })
                .bindPopup(`
                    <div style="min-width: 240px; font-family: -apple-system, BlinkMacSystemFont, sans-serif;">
                        <strong style="font-size: 1.05em; color: #0d6efd;">${a.name}</strong>
                        <hr style="margin: 6px 0;"/>
                        <div style="margin-bottom: 4px;">
                            <span style="opacity: 0.7;">📍</span> ${a.address}
                        </div>
                        <div style="margin-bottom: 10px;">
                            <span style="opacity: 0.7;">🕒</span> ${a.hours}
                        </div>
                        <a href="${directionsUrl}"
                           target="_blank"
                           rel="noopener noreferrer"
                           style="display: block; padding: 8px 12px; background: #0d6efd; color: white;
                                  text-align: center; text-decoration: none; border-radius: 6px;
                                  font-weight: 500; font-size: 0.9em;">
                            🧭 Get Directions
                        </a>
                    </div>
                `);
            markers.addLayer(marker);
        });
        markers.addTo(map);

        // Auto-fit bounds if we have pins
        if (agents.length > 0) {
            const group = L.featureGroup(markers.getLayers());
            map.fitBounds(group.getBounds().pad(0.15));
        }
    </script>
}