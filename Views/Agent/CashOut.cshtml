@{
    ViewData["Title"] = "Cash-Out Lookup";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="mb-3">💸 Cash-Out (OMT Pickup)</h3>
                    <p class="text-muted mb-4">
                        Customer is here to collect cash from an OMT transfer.
                        Enter the tracking number to look it up.
                    </p>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form asp-action="CashOutLookup" method="get">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Transfer tracking number</label>
                            <input type="text" name="tracking" class="form-control form-control-lg"
                                   placeholder="TRX-YYYYMMDD-XXXXXX" required />
                            <small class="form-text text-muted">
                                Ask the customer for the tracking number sent to them via SMS/email.
                            </small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                🔍 Look Up Transfer
                            </button>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <a asp-action="PendingPickups" class="btn btn-outline-secondary btn-sm">
                        📋 See all pending pickups
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>