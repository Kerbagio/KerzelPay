@model KerzelPay.Models.Agent
@{
    ViewData["Title"] = "Application Status";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    @switch (Model.Status)
                    {
                        case KerzelPay.Models.AgentStatus.Pending:
                            <div class="display-1">⏳</div>
                            <h3 class="text-warning">Under Review</h3>
                            <p class="lead">Your agent application is being reviewed by our team.</p>
                            <p class="text-muted">
                                Submitted: @Model.CreatedAt.ToString("dd MMM yyyy 'at' HH:mm")
                            </p>
                            break;

                        case KerzelPay.Models.AgentStatus.Approved:
                            <div class="display-1">✅</div>
                            <h3 class="text-success">Approved!</h3>
                            <p class="lead">Congratulations! You're now a Kerzel Pay agent.</p>
                            <a asp-action="Dashboard" class="btn btn-primary mt-3">Go to Agent Dashboard →</a>
                            break;

                        case KerzelPay.Models.AgentStatus.Rejected:
                            <div class="display-1">❌</div>
                            <h3 class="text-danger">Application Rejected</h3>
                            <p class="lead">Unfortunately, your application was not approved.</p>
                            <p class="text-muted">Please contact support for more information.</p>
                            break;

                        case KerzelPay.Models.AgentStatus.Suspended:
                            <div class="display-1">⚠️</div>
                            <h3 class="text-warning">Account Suspended</h3>
                            <p class="lead">Your agent account has been suspended.</p>
                            break;
                    }

                    <hr />

                    <dl class="row text-start mb-0">
                        <dt class="col-sm-4">Store name</dt>
                        <dd class="col-sm-8">@Model.StoreName</dd>

                        <dt class="col-sm-4">Address</dt>
                        <dd class="col-sm-8">@Model.Address</dd>

                        <dt class="col-sm-4">Working hours</dt>
                        <dd class="col-sm-8">@(Model.WorkingHours ?? "Not specified")</dd>

                        <dt class="col-sm-4">Coordinates</dt>
                        <dd class="col-sm-8">
                            <small>@Model.Latitude.ToString("F4"), @Model.Longitude.ToString("F4")</small>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>