@model KerzelPay.ViewModels.CashInViewModel
@{
    ViewData["Title"] = "Cash-In Operation";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="mb-3">💵 Cash-In Operation</h3>
                    <p class="text-muted mb-4">
                        Customer hands you cash → you credit their Kerzel Pay account.
                    </p>

                    <form asp-action="CashIn" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"
                             style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                        <div class="mb-3">
                            <label asp-for="CustomerAccountSerial" class="form-label fw-bold"></label>
                            <input asp-for="CustomerAccountSerial" class="form-control"
                                   placeholder="KP-2026-XXXXXX" style="text-transform: uppercase;" />
                            <span asp-validation-for="CustomerAccountSerial" class="text-danger"></span>
                            <small class="form-text text-muted">
                                Ask the customer to show you their account number from the app.
                            </small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label fw-bold">Cash amount received</label>
                            <input asp-for="Amount" type="number" step="0.01" min="0.01"
                                   class="form-control form-control-lg" placeholder="50.00" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                            <small class="form-text text-muted">
                                💡 You earn 0.5% commission on this transaction.
                            </small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Note" class="form-label"></label>
                            <textarea asp-for="Note" class="form-control" rows="2"
                                      placeholder="e.g. Customer paid in 50s and 10s"></textarea>
                        </div>

                        <div class="alert alert-warning small">
                            ⚠️ Make sure you have received the full cash amount before confirming.
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success btn-lg">
                                ✓ Confirm Cash-In
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}