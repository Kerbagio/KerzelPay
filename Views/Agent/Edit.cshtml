@model KerzelPay.ViewModels.AgentApplicationViewModel
@{
    ViewData["Title"] = "Become an Agent";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin="" />

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h3 class="mb-1">✏️ Edit my store</h3>
                            <p class="text-muted small mb-0">
                                ⚠️ Changes will require admin re-approval. Your agent role will be temporarily suspended.
                            </p>
                        </div>
                        <small class="text-muted">
                            📅 Applied on @DateTime.UtcNow.ToString("dd MMM yyyy")
                        </small>
                    </div>

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="All" class="alert alert-danger mb-3"
                             style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                        <!-- Store name -->
                        <div class="mb-3">
                            <label asp-for="StoreName" class="form-label fw-bold"></label>
                            <input asp-for="StoreName" class="form-control" placeholder="e.g. Beirut Express" />
                            <span asp-validation-for="StoreName" class="text-danger"></span>
                        </div>

                        <!-- Address -->
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-bold"></label>
                            <input asp-for="Address" class="form-control" placeholder="e.g. Hamra Main Street, Beirut" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <!-- Working hours (structured) -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">🕒 Working Hours</label>
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label asp-for="WorkingDays" class="form-label small text-muted">Days</label>
                                    <select asp-for="WorkingDays" class="form-select">
                                        <option value="Mon-Fri">Mon - Fri</option>
                                        <option value="Mon-Sat">Mon - Sat</option>
                                        <option value="Mon-Sun">Daily</option>
                                        <option value="Sat-Sun">Weekends only</option>
                                        <option value="Mon-Thu">Mon - Thu</option>
                                    </select>
                                    <span asp-validation-for="WorkingDays" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="OpenTime" class="form-label small text-muted">Open at</label>
                                    <input asp-for="OpenTime" type="time" class="form-control" />
                                    <span asp-validation-for="OpenTime" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="CloseTime" class="form-label small text-muted">Close at</label>
                                    <input asp-for="CloseTime" type="time" class="form-control" />
                                    <span asp-validation-for="CloseTime" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Location picker -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">📍 Pick your store location</label>
                            <p class="text-muted small mb-2">
                                Click anywhere on the map to drop a pin. Drag it to fine-tune the position.
                            </p>
                            <div id="pickMap" style="height: 400px; width: 100%; border: 1px solid #ddd; border-radius: 4px;"></div>

                            <input type="hidden" asp-for="Latitude" id="lat" />
                            <input type="hidden" asp-for="Longitude" id="lng" />

                            <div class="mt-2 small d-flex justify-content-between">
                                <span id="coordsLabel" class="text-muted">No location selected yet.</span>
                                <span id="locationStatus" class="text-danger" style="display: none;">
                                    ⚠️ You must click on the map to select a location
                                </span>
                            </div>
                            <span asp-validation-for="Latitude" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary" id="submitBtn">
                                Submit Application
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        const pickMap = L.map('pickMap').setView([33.8938, 35.5018], 11);

        const streets = L.tileLayer(
            'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',
            { attribution: '© OpenStreetMap contributors © CARTO', subdomains: 'abcd', maxZoom: 19 }
        );

        const satellite = L.tileLayer(
            'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
            { attribution: 'Tiles © Esri', maxZoom: 19 }
        );

        streets.addTo(pickMap);

        L.control.layers(
            { '🗺️ Streets': streets, '🛰️ Satellite': satellite },
            null,
            { position: 'topright', collapsed: false }
        ).addTo(pickMap);

        let marker = null;

        function updateFields(latlng) {
            document.getElementById('lat').value = latlng.lat.toFixed(6);
            document.getElementById('lng').value = latlng.lng.toFixed(6);
            document.getElementById('coordsLabel').innerHTML =
                `📍 Selected: <code>${latlng.lat.toFixed(6)}, ${latlng.lng.toFixed(6)}</code>`;
            document.getElementById('coordsLabel').classList.remove('text-muted');
            document.getElementById('coordsLabel').classList.add('text-success');
            document.getElementById('locationStatus').style.display = 'none';
        }

        pickMap.on('click', function (e) {
            if (marker) {
                marker.setLatLng(e.latlng);
            } else {
                marker = L.marker(e.latlng, { draggable: true }).addTo(pickMap);
                marker.on('dragend', function (event) {
                    updateFields(event.target.getLatLng());
                });
            }
            updateFields(e.latlng);
        });

        // Client-side guard: don't allow submit until a pin is dropped
        document.querySelector('form').addEventListener('submit', function (e) {
            const lat = document.getElementById('lat').value;
            const lng = document.getElementById('lng').value;

            if (!lat || !lng || (lat === '0' && lng === '0')) {
                e.preventDefault();
                document.getElementById('locationStatus').style.display = 'inline';
                document.getElementById('pickMap').scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    </script>
}