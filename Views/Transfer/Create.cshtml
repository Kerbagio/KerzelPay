@model KerzelPay.ViewModels.TransferViewModel
@{
    ViewData["Title"] = "Send Money";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="mb-4">💸 Send Money</h3>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"
                             style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                        <!-- Source account -->
                        <div class="mb-4">
                            <label asp-for="SourceAccountId" class="form-label fw-bold"></label>
                            <select asp-for="SourceAccountId" asp-items="ViewBag.Accounts" class="form-select">
                                <option value="">-- Choose account --</option>
                            </select>
                            <span asp-validation-for="SourceAccountId" class="text-danger"></span>
                        </div>

                        <!-- Transfer mode tabs -->
                        <label class="form-label fw-bold">Send to</label>
                        <ul class="nav nav-pills mb-3" role="tablist">
                            <li class="nav-item">
                                <button type="button" class="nav-link active" data-bs-toggle="pill"
                                        data-bs-target="#mode-beneficiary"
                                        onclick="document.getElementById('Mode').value='1'">
                                    👥 Beneficiary
                                </button>
                            </li>
                            <li class="nav-item">
                                <button type="button" class="nav-link" data-bs-toggle="pill"
                                        data-bs-target="#mode-account"
                                        onclick="document.getElementById('Mode').value='2'">
                                    🔢 Account #
                                </button>
                            </li>
                            <li class="nav-item">
                                <button type="button" class="nav-link" data-bs-toggle="pill"
                                        data-bs-target="#mode-mobile"
                                        onclick="document.getElementById('Mode').value='3'">
                                    📱 Mobile (OMT)
                                </button>
                            </li>
                        </ul>

                        <input type="hidden" asp-for="Mode" id="Mode" value="1" />

                        <div class="tab-content mb-3">
                            <!-- Beneficiary mode -->
                            <div class="tab-pane fade show active" id="mode-beneficiary">
                                <select asp-for="BeneficiaryId" asp-items="ViewBag.Beneficiaries" class="form-select">
                                    <option value="">-- Pick a beneficiary --</option>
                                </select>
                                <span asp-validation-for="BeneficiaryId" class="text-danger"></span>
                                <small class="form-text text-muted">
                                    Don't have a beneficiary yet?
                                    <a asp-controller="Beneficiary" asp-action="Create">Add one</a>.
                                </small>
                            </div>

                            <!-- Direct account mode -->
                            <div class="tab-pane fade" id="mode-account">
                                <input asp-for="DestinationSerial" class="form-control"
                                       placeholder="KP-2026-XXXXXX" style="text-transform: uppercase;" />
                                <span asp-validation-for="DestinationSerial" class="text-danger"></span>
                            </div>

                            <!-- Direct mobile mode -->
                            <div class="tab-pane fade" id="mode-mobile">
                                <div class="mb-2">
                                    <input asp-for="RecipientName" class="form-control" placeholder="Recipient name" />
                                    <span asp-validation-for="RecipientName" class="text-danger"></span>
                                </div>
                                <div>
                                    <input asp-for="RecipientMobile" class="form-control" placeholder="+961 71 234 567" />
                                    <span asp-validation-for="RecipientMobile" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Amount -->
                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label fw-bold"></label>
                            <input asp-for="Amount" type="number" step="0.01" min="0.01"
                                   class="form-control form-control-lg" placeholder="100.00" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                            <small class="form-text text-muted">
                                💡 A 1% commission is added on top of the amount.
                            </small>
                        </div>

                        <!-- Note -->
                        <div class="mb-4">
                            <label asp-for="Note" class="form-label">Note (optional)</label>
                            <textarea asp-for="Note" class="form-control" rows="2"
                                      placeholder="e.g. Rent for May"></textarea>
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success btn-lg">
                                Send →
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}