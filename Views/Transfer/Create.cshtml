@model KerzelPay.ViewModels.TransferViewModel
@{
    ViewData["Title"] = "Send Money";
    var accounts = ViewBag.Accounts as IEnumerable<KerzelPay.Models.Account> ?? Enumerable.Empty<KerzelPay.Models.Account>();
    var beneficiaries = ViewBag.Beneficiaries as IEnumerable<KerzelPay.Models.Beneficiary> ?? Enumerable.Empty<KerzelPay.Models.Beneficiary>();
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="mb-4">
                <span class="kp-eyebrow">Quick &amp; safe</span>
                <h2 class="mb-1">Send Money</h2>
                <p class="text-muted mb-0">Transfer to any Kerzel Pay account or to a mobile number for cash pickup.</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"
                 style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <form asp-action="Create" method="post" id="transferForm">
                @Html.AntiForgeryToken()

                <div class="kp-step-card">
                    <div class="kp-step-header">
                        <span class="kp-step-num">1</span>
                        <h5>From your account</h5>
                    </div>
                    <div class="kp-step-body">
                        <select asp-for="SourceAccountId" class="form-select form-select-lg"
                                asp-items="@(new SelectList(accounts, "Id", "SerialNumber"))">
                            <option value="">— Pick an account —</option>
                        </select>
                        <span asp-validation-for="SourceAccountId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="kp-step-card">
                    <div class="kp-step-header">
                        <span class="kp-step-num">2</span>
                        <h5>Who's it going to?</h5>
                    </div>
                    <div class="kp-step-body">
                        <div class="kp-mode-tabs">
                            <input type="radio" asp-for="Mode" value="Beneficiary" id="modeBen" />
                            <label for="modeBen" class="kp-mode-tab">
                                <span>👥</span><strong>Saved beneficiary</strong>
                            </label>

                            <input type="radio" asp-for="Mode" value="DirectAccount" id="modeAcc" />
                            <label for="modeAcc" class="kp-mode-tab">
                                <span>💳</span><strong>Account number</strong>
                            </label>

                            <input type="radio" asp-for="Mode" value="DirectMobile" id="modeMob" />
                            <label for="modeMob" class="kp-mode-tab">
                                <span>📱</span><strong>Mobile (OMT)</strong>
                            </label>
                        </div>

                        @* Beneficiary picker *@
                        <div class="kp-mode-panel" data-mode="Beneficiary">
                            @if (!beneficiaries.Any())
                            {
                                <p class="text-muted small mb-2">
                                    You have no saved beneficiaries.
                                    <a asp-controller="Beneficiary" asp-action="Create">Add one →</a>
                                </p>
                            }
                            else
                            {
                                <select asp-for="BeneficiaryId" class="form-select"
                                        asp-items="@(new SelectList(beneficiaries, "Id", "Nickname"))">
                                    <option value="">— Choose beneficiary —</option>
                                </select>
                            }
                        </div>

                        @* Direct account *@
                        <div class="kp-mode-panel" data-mode="DirectAccount">
                            <input asp-for="DestinationSerial" class="form-control"
                                   placeholder="KP-2026-XXXXXX" style="text-transform: uppercase;" />
                            <span asp-validation-for="DestinationSerial" class="text-danger small"></span>
                        </div>

                        @* Direct mobile *@
                        <div class="kp-mode-panel" data-mode="DirectMobile">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <input asp-for="RecipientName" class="form-control" placeholder="Recipient name" />
                                    <span asp-validation-for="RecipientName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <input asp-for="RecipientMobile" class="form-control" placeholder="+961 71 234 567" />
                                    <span asp-validation-for="RecipientMobile" class="text-danger small"></span>
                                </div>
                            </div>
                            <p class="small text-muted mt-2 mb-0">
                                💡 Recipient picks up cash at any approved Kerzel Pay agent.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="kp-step-card">
                    <div class="kp-step-header">
                        <span class="kp-step-num">3</span>
                        <h5>How much?</h5>
                    </div>
                    <div class="kp-step-body">
                        <div class="row g-2">
                            <div class="col-md-8">
                                <input asp-for="Amount" type="number" step="0.01" class="form-control form-control-lg"
                                       placeholder="100.00" />
                                <span asp-validation-for="Amount" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <textarea asp-for="Note" class="form-control" rows="1" placeholder="Note (optional)"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-controller="Account" asp-action="Index" class="btn btn-outline-secondary btn-lg">← Cancel</a>
                    <button type="submit" class="btn btn-primary btn-lg">Send transfer →</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const radios = document.querySelectorAll('input[name="Mode"]');
            const panels = document.querySelectorAll('.kp-mode-panel');

            function update() {
                const checked = document.querySelector('input[name="Mode"]:checked');
                const value = checked ? checked.value : 'Beneficiary';
                panels.forEach(p => p.style.display = p.dataset.mode === value ? 'block' : 'none');
            }
            radios.forEach(r => r.addEventListener('change', update));
            update();
        })();
    </script>
}