@model KerzelPay.Models.Transfer
@{
    ViewData["Title"] = "Receipt";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="kp-receipt">
                <div class="kp-receipt-header">
                    <img src="~/img/logo.svg" alt="Kerzel Pay" />
                    <div>
                        <div class="kp-receipt-badge">
                            @if (Model.Status == KerzelPay.Models.TransferStatus.Completed)
                            {
                                <span class="badge bg-success">✓ Completed</span>
                            }
                            else if (Model.Status == KerzelPay.Models.TransferStatus.Pending)
                            {

                                <span class="badge bg-warning">⏳ Pending</span>
                            }
                            else
                            {

                                <span class="badge bg-danger">@Model.Status</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="kp-receipt-amount">
                    <div class="kp-receipt-label">Amount sent</div>
                    <div class="kp-receipt-big">@Model.SourceCurrencyCode @Model.Amount.ToString("N2")</div>
                    @if (Model.SourceCurrencyCode != Model.DestinationCurrencyCode)
                    {
                        <div class="kp-receipt-label mt-1">
                            ≈ @Model.DestinationCurrencyCode @Model.ConvertedAmount.ToString("N2")
                        </div>
                    }
                </div>

                <div class="kp-receipt-divider"></div>

                <div class="kp-receipt-row">
                    <span>Tracking number</span>
                    <strong><code>@Model.TrackingNumber</code></strong>
                </div>
                <div class="kp-receipt-row">
                    <span>Date</span>
                    <strong>@Model.CreatedAt.ToString("dd MMM yyyy · HH:mm")</strong>
                </div>
                <div class="kp-receipt-row">
                    <span>Type</span>
                    <strong>@Model.Type</strong>
                </div>
                @if (Model.SourceAccount != null)
                {
                    <div class="kp-receipt-row">
                        <span>From</span>
                        <strong><code>@Model.SourceAccount.SerialNumber</code></strong>
                    </div>
                }
                @if (Model.DestinationAccount != null)
                {
                    <div class="kp-receipt-row">
                        <span>To account</span>
                        <strong><code>@Model.DestinationAccount.SerialNumber</code></strong>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.RecipientName))
                {
                    <div class="kp-receipt-row">
                        <span>Recipient</span>
                        <strong>@Model.RecipientName <small class="text-muted">(@Model.RecipientMobile)</small></strong>
                    </div>
                }
                @if (Model.ExchangeRate != 1m)
                {
                    <div class="kp-receipt-row">
                        <span>Exchange rate</span>
                        <strong>1 @Model.SourceCurrencyCode = @Model.ExchangeRate.ToString("N6") @Model.DestinationCurrencyCode</strong>
                    </div>
                }
                <div class="kp-receipt-row">
                    <span>Commission</span>
                    <strong>@Model.SourceCurrencyCode @Model.Commission.ToString("N2")</strong>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Note))
                {
                    <div class="kp-receipt-row">
                        <span>Note</span>
                        <strong style="text-align: right; max-width: 60%;">@Model.Note</strong>
                    </div>
                }

                <div class="kp-receipt-divider"></div>

                <div class="kp-receipt-footer">
                    💸 Powered by Kerzel Pay · @DateTime.Now.Year
                </div>
            </div>

            <div class="d-flex justify-content-center gap-2 mt-4 d-print-none">
                <a asp-controller="Account" asp-action="Index" class="btn btn-outline-secondary">← My accounts</a>
                <button onclick="window.print()" class="btn btn-primary">🖨️ Print receipt</button>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .navbar, .footer, .d-print-none, #kerzelChatWidget {
            display: none !important;
        }

        body {
            background: white !important;
        }

        .kp-receipt {
            box-shadow: none !important;
            border: 1px solid #ccc !important;
        }
    }
</style>