@model KerzelPay.ViewModels.CreateAccountViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="mb-4">Create a new account</h3>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CurrencyId" class="form-label"></label>
                            <select asp-for="CurrencyId"
                                    asp-items="ViewBag.Currencies"
                                    class="form-select">
                                <option value="">-- Select a currency --</option>
                            </select>
                            <span asp-validation-for="CurrencyId" class="text-danger"></span>
                            <small class="form-text text-muted">
                                You can have multiple accounts in different currencies.
                            </small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Create Account</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}