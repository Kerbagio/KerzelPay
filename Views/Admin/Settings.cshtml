@{
    ViewData["Title"] = "Settings";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2>⚙️ Settings</h2>
        <a asp-action="Dashboard" class="btn btn-sm btn-outline-secondary">← Dashboard</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning">@TempData["Error"]</div>
    }

    <!-- Platform commission -->
    <div class="card shadow-sm mb-4" style="max-width: 600px;">
        <div class="card-body">
            <h5 class="mb-3">💼 Platform Commission</h5>
            <p class="text-muted small mb-3">
                Percentage charged by Kerzel Pay on every user-to-user transfer
                (e.g. <code>1.0</code> means 1%).
            </p>

            <form asp-action="UpdateCommission" method="post">
                @Html.AntiForgeryToken()
                <div class="input-group mb-3" style="max-width: 250px;">
                    <input type="number" name="commissionPercent"
                           value="@ViewBag.CommissionPercent"
                           step="0.1" min="0" max="50"
                           class="form-control" />
                    <span class="input-group-text">%</span>
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </form>
        </div>
    </div>

    <!-- Agent commission -->
    <div class="card shadow-sm" style="max-width: 600px;">
        <div class="card-body">
            <h5 class="mb-3">🏪 Agent Commission</h5>
            <p class="text-muted small mb-3">
                Percentage earned by an agent on each cash-in or cash-out operation
                (e.g. <code>0.5</code> means 0.5%).
            </p>

            <form asp-action="UpdateAgentCommission" method="post">
                @Html.AntiForgeryToken()
                <div class="input-group mb-3" style="max-width: 250px;">
                    <input type="number" name="agentCommissionPercent"
                           value="@ViewBag.AgentCommissionPercent"
                           step="0.1" min="0" max="50"
                           class="form-control" />
                    <span class="input-group-text">%</span>
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </form>
        </div>
    </div>
</div>