@model IEnumerable<KerzelPay.Models.ApplicationUser>
@{
    ViewData["Title"] = "Users";
    var roles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
    var query = ViewBag.Query as string;
    var roleFilter = ViewBag.RoleFilter as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2>👥 Users (@Model.Count())</h2>
        <a asp-action="Dashboard" class="btn btn-sm btn-outline-secondary">← Dashboard</a>
    </div>

    <form asp-action="Users" method="get" class="row g-2 mb-3">
        <div class="col-md-6">
            <input type="text" name="q" value="@query" class="form-control" placeholder="Search by name or email..." />
        </div>
        <div class="col-md-3">
            <select name="role" class="form-select">
                <option value="">All roles</option>
                <option value="Admin" selected="@(roleFilter == "Admin")">Admin</option>
                <option value="Agent" selected="@(roleFilter == "Agent")">Agent</option>
                <option value="User" selected="@(roleFilter == "User")">User</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </form>

    <div class="card shadow-sm">
        <table class="table mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Email</th><th>Roles</th><th>Created</th><th class="text-end">Role Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    var userRoleList = roles != null && roles.TryGetValue(u.Id, out var r) ? r : new List<string>();

                    <tr>
                        <td>
                            @u.FirstName @u.LastName
                        </td>
                        <td>
                            <small>@u.Email</small>
                        </td>
                        <td>
                            @foreach (var role in userRoleList)
                            {
                                <span class="badge bg-secondary me-1">@role</span>
                            }
                        </td>
                        <td>
                            <small class="text-muted">@u.CreatedAt.ToString("dd MMM yyyy")</small>
                        </td>
                        <td class="text-end">
                            @if (u.Email?.ToLower() != ViewBag.SuperAdminEmail?.ToString().ToLower())
                            {
                                <!-- Add role dropdown -->
                                <div class="dropdown d-inline">
                                    <button class="btn btn-sm btn-outline-success dropdown-toggle"
                                            data-bs-toggle="dropdown">
                                        + Role
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        @foreach (var role in new[] { "Admin", "Agent", "User" })
                                        {
                                            @if (!userRoleList.Contains(role))
                                            {
                                                <li>
                                                    <form asp-action="AddRole" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="userId" value="@u.Id" />
                                                        <input type="hidden" name="role" value="@role" />
                                                        <button type="submit" class="dropdown-item">
                                                            Add @role
                                                        </button>
                                                    </form>
                                                </li>
                                            }
                                        }
                                    </ul>
                                </div>

                                @if (userRoleList.Any())
                                {
                                    <div class="dropdown d-inline">
                                        <button class="btn btn-sm btn-outline-danger dropdown-toggle"
                                                data-bs-toggle="dropdown">
                                            − Role
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            @foreach (var role in userRoleList)
                                            {
                                                <li>
                                                    <form asp-action="RemoveRole" method="post"
                                                          onsubmit="return confirm('Remove @role role from @u.Email?')">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="userId" value="@u.Id" />
                                                        <input type="hidden" name="role" value="@role" />
                                                        <button type="submit" class="dropdown-item text-danger">
                                                            Remove @role
                                                        </button>
                                                    </form>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }

                                @* Delete user *@
                                <a asp-action="DeleteUser" asp-route-id="@u.Id"
                                   class="btn btn-sm btn-outline-danger ms-1"
                                   title="Delete user">
                                    🗑️
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-dark">🔒 Super Admin</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>