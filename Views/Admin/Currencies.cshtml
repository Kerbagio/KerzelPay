@model IEnumerable<KerzelPay.Models.Currency>
@{
    ViewData["Title"] = "Currencies";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2>💱 Currencies</h2>
        <a asp-action="Dashboard" class="btn btn-sm btn-outline-secondary">← Dashboard</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning">@TempData["Error"]</div>
    }

    <div class="alert alert-info">
        💡 Rates are stored as <strong>"how many of this currency = 1 USD"</strong>.
        LBP is manually managed by admin — the API refresh skips it.
    </div>

    <form asp-action="RefreshRates" method="post" class="mb-3">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary">
            🔄 Refresh Live Rates (Frankfurter / ECB)
        </button>
    </form>

    <div class="card shadow-sm">
        <table class="table mb-0">
            <thead class="table-light">
                <tr><th>Code</th><th>Name</th><th>Rate (per USD)</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <form asp-action="UpdateCurrency" asp-route-id="@c.Id" method="post">
                            @Html.AntiForgeryToken()
                        <td><strong>@c.Symbol @c.Code</strong></td>
                        <td>@c.Name</td>
                        <td>
                            <input type="number" name="rate" value="@c.ExchangeRateToUsd"
                                   step="0.000001" min="0" class="form-control form-control-sm"
                                   style="width: 150px;" />
                        </td>
                        <td>
                            <div class="form-check form-switch">
                                <input type="checkbox" name="isActive" value="true"
                                       class="form-check-input" @(c.IsActive ? "checked" : "") />
                            </div>
                        </td>
                        <td><button type="submit" class="btn btn-sm btn-primary">Save</button></td>
                        </form>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>