@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Views/Shared/_Layout.cshtml";
    }
}

<div class="container py-4">
    <div class="mb-4">
        <span class="kp-eyebrow">Settings</span>
        <h2 class="mb-1">Manage your account</h2>
        <p class="text-muted">Update your profile, email, password, and security preferences.</p>
    </div>

    <div class="row g-4">
        <aside class="col-lg-3">
            <nav class="kp-settings-nav">
                <partial name="_ManageNav" />
            </nav>
        </aside>
        <div class="col-lg-9">
            <div class="kp-settings-content">
                @RenderBody()
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}