@inject SignInManager<KerzelPay.Models.ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<ul class="kp-settings-list">
    <li>
        <a class="kp-settings-link @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">
            <span>👤</span> Profile
        </a>
    </li>
    <li>
        <a class="kp-settings-link @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">
            <span>✉️</span> Email
        </a>
    </li>
    <li>
        <a class="kp-settings-link @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">
            <span>🔑</span> Password
        </a>
    </li>
    @if (hasExternalLogins)
    {
        <li>
            <a class="kp-settings-link @ManageNavPages.ExternalLoginsNavClass(ViewContext)" id="external-login" asp-page="./ExternalLogins">
                <span>🔗</span> External logins
            </a>
        </li>
    }
    <li>
        <a class="kp-settings-link @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">
            <span>🛡️</span> Two-factor auth
        </a>
    </li>
    <li>
        <a class="kp-settings-link @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">
            <span>📦</span> Personal data
        </a>
    </li>
</ul>