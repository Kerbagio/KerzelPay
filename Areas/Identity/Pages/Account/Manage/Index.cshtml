@model IEnumerable<KerzelPay.Models.Account>
@{
    ViewData["Title"] = "My Accounts";
}

<div class="container py-4">
    @* === Header === *@
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <span class="kp-eyebrow">Your wallets</span>
            <h2 class="mb-0">My Accounts</h2>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            + New account
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        @* === Empty state === *@
        <div class="kp-empty-state">
            <div class="kp-empty-icon">💳</div>
            <h4>No accounts yet</h4>
            <p>Create your first multi-currency wallet in seconds. You can add USD, EUR, GBP, or LBP accounts.</p>
            <a asp-action="Create" class="btn btn-primary btn-lg">Create your first account</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @{
                var gradients = new[]
                {
                "linear-gradient(135deg, #0066FF 0%, #00D4AA 100%)",
                "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
                "linear-gradient(135deg, #f093fb 0%, #f5576c 100%)",
                "linear-gradient(135deg, #f6d365 0%, #fda085 100%)",
                "linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)"
                };
                var i = 0;
            }
            @foreach (var a in Model)
            {
                var grad = gradients[i % gradients.Length]; i++;
                <div class="col-md-6 col-xl-4">
                    <div class="kp-wallet" style="background: @grad;">
                        <div class="kp-wallet-pattern"></div>
                        <div class="kp-wallet-top">
                            <span class="kp-wallet-chip">●</span>
                            <span class="kp-wallet-currency">@a.Currency.Code</span>
                        </div>
                        <div class="kp-wallet-serial">@a.SerialNumber</div>
                        <div class="kp-wallet-bottom">
                            <div>
                                <div class="kp-wallet-label">BALANCE</div>
                                <div class="kp-wallet-amount">
                                    @a.Currency.Symbol @a.Balance.ToString("N2")
                                </div>
                            </div>
                            <div class="kp-wallet-logo">KMP</div>
                        </div>

                        <div class="kp-wallet-actions">
                            <a asp-controller="TopUp" asp-action="Index" asp-route-accountId="@a.Id"
                               class="kp-wallet-action" title="Top up">
                                💰
                            </a>
                            <a asp-controller="Transfer" asp-action="Create" asp-route-fromId="@a.Id"
                               class="kp-wallet-action" title="Send">
                                ↗
                            </a>
                            <form asp-action="Delete" asp-route-id="@a.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this account?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="kp-wallet-action" title="Delete">🗑️</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>